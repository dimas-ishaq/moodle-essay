# ================================================================
# MOODLE ESSAY AUTO-GRADER - CONFIGURATION FILE
# ================================================================
# Copy ini ke file bernama .env dan isi dengan nilai sebenarnya
# JANGAN SHARE file ini ke public karena berisi credentials!
# ================================================================

# ================================================================
# 🔐 MOODLE CONFIGURATION
# ================================================================

# URL Moodle Anda (TANPA trailing slash)
# Contoh: https://moodle.universitas.ac.id
# atau:   http://localhost/moodle
MOODLE_URL=

# Username untuk login (biasanya admin atau teacher account)
MOODLE_USERNAME=

# Password untuk login (gunakan password yang aman)
MOODLE_PASSWORD=

# Course ID - lihat di URL course: ...&id=X
# Cara dapat: Login Moodle → Buka course → URL: course/view.php?id=123
MOODLE_COURSE_ID=3

# Assignment/Quiz ID - lihat di URL assignment
# Cara dapat: Buka assignment → URL: mod/assign/view.php?id=456
MOODLE_QUIZ_ID=15

# ================================================================
# 🤖 OPENAI CONFIGURATION
# ================================================================

# OpenAI API Key - dapatkan dari https://platform.openai.com/api-keys
# Format: sk-proj-xxxxxxxxxxxxx (mulai dengan "sk-")
# PENTING: JANGAN SHARE KEY INI!
OPENAI_API_KEY=sk-your-api-key-here

# Model OpenAI yang digunakan
# Pilihan:
#   - gpt-4         : Paling akurat, paling mahal (~$0.03 per submission)
#   - gpt-4-turbo   : Good balance (~$0.01 per submission) ⭐ RECOMMENDED
#   - gpt-3.5-turbo : Paling murah (~$0.0005 per submission)
OPENAI_MODEL=gpt-4

# Custom OpenAI-compatible base URL (opsional)
# Isi jika ingin pakai endpoint/proxy custom, misalnya:
# OPENAI_BASE_URL=https://example.com/v1
# Kosongkan jika memakai OpenAI default
OPENAI_BASE_URL=

# Temperature (0.0 - 2.0) - mengontrol consistency jawaban
# 0.0   = Paling consistent (sama persis tiap kali)
# 0.3   = Recommended untuk grading (consistent tapi natural)
# 1.0   = Default OpenAI
# 2.0   = Paling random/creative
OPENAI_TEMPERATURE=0.3

# Maximum tokens per response
# Lebih tinggi = lebih detail feedback (tapi lebih mahal)
# 200  = Minimal (hanya skor + alasan singkat)
# 500  = Recommended (skor + reasoning + strengths/improvements)
# 1000 = Detailed (comprehensive analysis)
OPENAI_MAX_TOKENS=500

# ================================================================
# ⚙️ PERFORMANCE & GRADING CONFIGURATION
# ================================================================

# Poin scale (100 atau disesuaikan)
POINTS_SCALE=12

# Minimum points
MIN_POINTS=6

# Maximum points
MAX_POINTS=12

# Batch size untuk processing (tidak terlalu penting di version ini)
BATCH_SIZE=10

# Jumlah concurrent requests ke OpenAI
# 1   = Paling aman, paling lambat (~2430 submissions = 20+ jam)
# 3   = Balanced ⭐ RECOMMENDED (~2430 submissions = 6-8 jam)
# 5   = Cepat tapi risiko rate limiting (~2430 submissions = 4-5 jam)
# 10+ = Sangat cepat tapi besar risiko error
CONCURRENT_REQUESTS=3

# Timeout untuk tiap request (milliseconds)
# 30000 = 30 detik (standard)
# 60000 = 60 detik (untuk koneksi lambat)
TIMEOUT_MS=30000

# ================================================================
# 🔄 RETRY & DELAY CONFIGURATION
# ================================================================

# Delay antara submissions (milliseconds)
# Ini untuk avoid rate limiting di Moodle & OpenAI
# 300-500   = Aggressive (fast tapi risiko)
# 1000      = Recommended ⭐
# 2000+     = Conservative (lambat tapi aman)
RETRY_DELAY_MS=1000

# Maximum retry attempts jika ada error
# 3 = Standard
# 5 = Lebih toleran untuk network error
MAX_RETRIES=3

# Delay sebelum retry (milliseconds)
# Menggunakan exponential backoff: delay * 2^attempt
RETRY_DELAY_MS=2000

# ================================================================
# 📁 RUBRIC & GRADING CRITERIA
# ================================================================

# Path ke file panduan rubrik (opsional)
# Jika tidak di-set, akan gunakan default ./rubric.md
# Buat file rubric.md berisi panduan penilaian
RUBRIC_GUIDE_FILE=./rubric.md

# ================================================================
# 📊 LOGGING CONFIGURATION
# ================================================================

# Log level: error | warn | info | debug
# error = Hanya error messages
# warn  = Warnings dan error
# info  = Info, warnings, dan error ⭐ RECOMMENDED
# debug = Semua termasuk detailed debug info (verbose)
LOG_LEVEL=info

# Log file path
LOG_FILE=./logs/grading.log

# ================================================================
# 🔧 ADVANCED OPTIONS
# ================================================================

# Checkpoint interval - save progress setiap N submissions
# Useful untuk resume jika terjadi error
# 50 = Save setiap 50 submissions (good balance)
CHECKPOINT_INTERVAL=50

# Backup sebelum grading
CREATE_BACKUP=true

# Email notification setelah selesai (future feature)
# NOTIFY_EMAIL=admin@universitas.ac.id

# ================================================================
# 📝 NOTES & TIPS
# ================================================================

# Untuk 2,430 essays (486 × 5 soal):
#
# Konfigurasi FAST (4-5 jam, ~$3):
#   OPENAI_MODEL=gpt-3.5-turbo
#   OPENAI_MAX_TOKENS=300
#   CONCURRENT_REQUESTS=5
#   RETRY_DELAY_MS=500
#
# Konfigurasi BALANCED (6-8 jam, ~$5-10):
#   OPENAI_MODEL=gpt-4-turbo
#   OPENAI_MAX_TOKENS=500
#   CONCURRENT_REQUESTS=3
#   RETRY_DELAY_MS=1000
#
# Konfigurasi QUALITY (10-12 jam, $20-30):
#   OPENAI_MODEL=gpt-4
#   OPENAI_MAX_TOKENS=800
#   CONCURRENT_REQUESTS=2
#   RETRY_DELAY_MS=2000

# ================================================================
# ⚠️ SECURITY NOTES
# ================================================================

# 1. JANGAN share file .env ini ke git/public
# 2. Add .env ke .gitignore
# 3. Ganti password/API key jika di-share atau di-leak
# 4. Gunakan environment variables untuk production
# 5. Batasi akses ke file .env (chmod 600)

# ================================================================
# 🧪 TESTING CONFIGURATION
# ================================================================

# Untuk testing, uncomment dan set limit submissions:
# TEST_MODE=true
# TEST_SUBMISSION_LIMIT=5

# ================================================================
