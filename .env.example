# Moodle Configuration
MOODLE_URL=https://your-moodle-domain.com
MOODLE_USERNAME=your_username
MOODLE_PASSWORD=your_password
MOODLE_COURSE_ID=3
MOODLE_QUIZ_ID=15

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=500

# Grading Configuration
POINTS_SCALE=100
MIN_POINTS=0
MAX_POINTS=100
BATCH_SIZE=10
CONCURRENT_REQUESTS=3
TIMEOUT_MS=30000
REGRADE_AGAIN=true
REGRADE_THRESHOLD=40

# Rubric (Optional - untuk custom rubric)
RUBRIC_GUIDE_FILE=./rubric.md

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/grading.log

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY_MS=2000
